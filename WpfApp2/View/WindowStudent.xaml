<Window x:Class="WpfApp2.View.WindowStudent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Студенты" Height="450" Width="900">
    <StackPanel Margin="10">
        <Label FontSize="16" FontWeight="Bold" HorizontalAlignment="Center">
            Список студентов
        </Label>

        <!-- Панель кнопок -->
        <StackPanel Background="#FFD8D8D8">
            <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
                <Button x:Name="btnAdd" Margin="10,10,5,10" Content="Добавить" 
                        Height="25" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Margin="10,10,5,10" Content="Редактировать" 
                        Height="25" Click="btnEdit_Click"/>
                <Button x:Name="btnDelete" Margin="10,10,5,10" Content="Удалить" 
                        Height="25" Click="btnDelete_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ListView с данными -->
        <ListView x:Name="lvStudent" Margin="5" Height="320" Background="#FFD3CDCD">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="40" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Фамилия" Width="120" DisplayMemberBinding="{Binding LastName}"/>
                    <GridViewColumn Header="Имя" Width="100" DisplayMemberBinding="{Binding FirstName}"/>
                    <GridViewColumn Header="Отчество" Width="120" DisplayMemberBinding="{Binding MiddleName}"/>
                    <GridViewColumn Header="Группа" Width="90" DisplayMemberBinding="{Binding GroupName}"/>
                    <GridViewColumn Header="Спец." Width="130" DisplayMemberBinding="{Binding Specialty}"/>
                    <GridViewColumn Header="Курс" Width="50" DisplayMemberBinding="{Binding Course}"/>
                    <GridViewColumn Header="Дата рождения" Width="100" 
                                    DisplayMemberBinding="{Binding BirthDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    <GridViewColumn Header="Ср. балл" Width="70" 
                                    DisplayMemberBinding="{Binding AverageGrade, StringFormat={}{0:0.0}}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>
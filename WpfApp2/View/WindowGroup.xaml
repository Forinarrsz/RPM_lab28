<Window x:Class="WpfApp2.View.WindowGroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учебные группы" Height="350" Width="600"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="10">
        <!-- Заголовок -->
        <Label FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10">
            Список учебных групп
        </Label>

        <!-- Панель с кнопками -->
        <StackPanel Background="#FFD8D8D8" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
                <Button Style="{StaticResource ButtonMenu}" 
                        Content="Добавить" 
                        Command="{Binding AddGroup}"/>
                <Button Style="{StaticResource ButtonMenu}" 
                        Content="Редактировать" 
                        Command="{Binding EditGroup}"/>
                <Button Style="{StaticResource ButtonMenu}" 
                        Content="Удалить" 
                        Command="{Binding DeleteGroup}"/>
            </StackPanel>
            <Label Margin="5" HorizontalAlignment="Center" FontWeight="Bold">Список групп</Label>
        </StackPanel>

        <!-- Список групп с привязкой данных -->
        <ListView x:Name="lvGroup" 
                  Margin="5" 
                  Height="220" 
                  Background="#FFD3CDCD"
                  ItemsSource="{Binding ListGroup}"
                  SelectedItem="{Binding SelectedGroup, Mode=TwoWay}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Код" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Группа" Width="120" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Специальность" Width="200" DisplayMemberBinding="{Binding Specialty}"/>
                    <GridViewColumn Header="Курс" Width="60" DisplayMemberBinding="{Binding Course}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>
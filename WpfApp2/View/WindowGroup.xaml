<Window x:Class="WpfApp2.View.WindowGroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учебные группы" Height="350" Width="600">
    <StackPanel Margin="10">
        <Label FontSize="16" FontWeight="Bold" HorizontalAlignment="Center">
            Список учебных групп
        </Label>

        <StackPanel Background="#FFD8D8D8">
            <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
                <Button x:Name="btnAdd" Margin="10,10,5,10" Content="Добавить" 
                        Height="25" Click="btnAdd_Click"/>
                <Button x:Name="btnEdit" Margin="10,10,5,10" Content="Редактировать" 
                        Height="25" Click="btnEdit_Click"/>
                <Button x:Name="btnDelete" Margin="10,10,5,10" Content="Удалить" 
                        Height="25" Click="btnDelete_Click"/>
            </StackPanel>
            <Label Margin="5" HorizontalAlignment="Center">Список групп</Label>
        </StackPanel>

        <ListView x:Name="lvGroup" Margin="5" Height="250" Background="#FFD3CDCD">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Код" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Группа" Width="100" DisplayMemberBinding="{Binding GroupName}"/>
                    <GridViewColumn Header="Специальность" Width="150" DisplayMemberBinding="{Binding Specialty}"/>
                    <GridViewColumn Header="Курс" Width="60" DisplayMemberBinding="{Binding Course}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>
<Window x:Class="WpfApp2.View.WindowNewGroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Группа" Height="262" Width="411"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="50*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Код:" 
                   VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,22,13,0" Grid.RowSpan="2" Height="37"/>
        <TextBlock Grid.Column="0" Text="Группа:" 
                   VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,13,0" Grid.Row="1"/>
        <TextBlock Grid.Row="1" Text="Специальность:" 
                   VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0" Grid.RowSpan="2"/>
        <TextBlock Grid.Row="2" Text="Курс:" 
                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="32,42,0,0" RenderTransformOrigin="0.738,1.253" Grid.RowSpan="2"/>

        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbId" 
                 Text="{Binding Id}" IsEnabled="False" Margin="8,10,2,20" Height="23"/>
        <TextBox Grid.Column="1" x:Name="TbGroupName" 
                 Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" Margin="8,5,2,25" Height="23" Grid.Row="1"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbSpecialty" 
                 Text="{Binding Specialty, UpdateSourceTrigger=PropertyChanged}" Margin="8,37,2,47" Height="23" Grid.RowSpan="2"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CbCourse" 
                  SelectedValue="{Binding Course}" Margin="8,38,2,59" Height="23" Grid.RowSpan="2">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
        </ComboBox>

        <StackPanel Grid.Row="3" Grid.Column="1" 
                    Orientation="Horizontal" HorizontalAlignment="Left" Margin="99,10,0,10" Width="175">
            <Button x:Name="BtnSave" Content="Сохранить" Width="80" Height="25" 
                    Margin="5" IsDefault="True" Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel" Content="Отменить" Width="80" Height="25" 
                    Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
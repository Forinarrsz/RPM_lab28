<Window x:Class="WpfApp2.View.WindowNewGroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Группа" Height="280" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="50*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Код:" 
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Группа:" 
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Специальность:" 
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Курс:" 
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5"/>

        <TextBox Grid.Row="0" Grid.Column="1" 
                 Text="{Binding Id, Mode=OneWay}" IsEnabled="False" 
                 Margin="5" Height="23"/>

        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                 Margin="5" Height="23"/>

        <TextBox Grid.Row="2" Grid.Column="1" 
                 Text="{Binding Specialty, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                 Margin="5" Height="23"/>

        <TextBox Grid.Row="3" Grid.Column="1" 
                 Text="{Binding Course, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                 Margin="5" Height="23"/>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="Сохранить" Width="80" Height="25" 
                    Margin="5" IsDefault="True" Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel" Content="Отменить" Width="80" Height="25" 
                    Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>